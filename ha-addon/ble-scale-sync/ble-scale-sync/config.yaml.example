version: 1

ble:
  # Optional: set your scale MAC for reliable matching
  # scale_mac: "FF:03:00:13:A1:04"

scale:
  weight_unit: kg
  height_unit: cm

unknown_user: nearest

users:
  - name: Your Name
    slug: you
    height: 175
    birth_date: "1990-01-01"
    gender: male
    is_athlete: false
    weight_range: { min: 60, max: 90 }
    last_known_weight: null

    exporters:
      - type: garmin
        email: "${GARMIN_EMAIL}"
        password: "${GARMIN_PASSWORD}"
        token_dir: /data/garmin_tokens

runtime:
  continuous_mode: true
  scan_cooldown: 30
  dry_run: false
  debug: false
